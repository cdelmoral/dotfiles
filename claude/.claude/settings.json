{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus[1m]",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh run view *)",
      "Bash(npm run typecheck *)",
      "Bash(npm run lint *)",
      "Bash(npm run prettier *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(git diff *)"
    ],
    "deny": []
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  }
}
