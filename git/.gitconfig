[user]
	name = Carlos del Moral
[commit]
  gpgsign = true
[mergetool]
	keepBackup = false
	prompt = false
[mergetool "diffview"]
	cmd = nvim -c \"DiffviewOpen\"
[diff]
	tool = nvimdiff
	ignoreWhitespace = true
[alias]
	lg = log --oneline --graph --decorate --all
[core]
	excludesfile = ~/.gitignore_global
	pager = delta
	commentChar = ";"
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
	tool = diffview
[include]
  path = ~/.gitconfig.local
