#!/usr/bin/env bash
# create-worktree.sh — interactive git worktree creator (requires fzf)

set -euo pipefail

# ─── colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

err() { echo -e "${RED}✖  $*${RESET}" >&2; }
info() { echo -e "${CYAN}→  $*${RESET}"; }
ok() { echo -e "${GREEN}✔  $*${RESET}"; }
hdr() { echo -e "\n${BOLD}${YELLOW}$*${RESET}"; }

# ─── guards ──────────────────────────────────────────────────────────────────
if ! command -v fzf &>/dev/null; then
  err "fzf is not installed. Run: brew install fzf  (or see https://github.com/junegunn/fzf)"
  exit 1
fi

if ! git rev-parse --git-dir &>/dev/null; then
  err "Not inside a git repository. Aborting."
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
REPO_NAME=$(basename "$REPO_ROOT")

# ─── simple prompt with optional default ─────────────────────────────────────
# Prints the entered value to stdout; prompt goes to stderr so it doesn't
# pollute command substitution. Bash 3.2 compatible (no namerefs).
ask() {
  local prompt="$1"
  local default="${2:-}"

  local display_prompt="${BOLD}${CYAN}${prompt}${RESET}"
  [[ -n "$default" ]] && display_prompt+=" ${YELLOW}[${default}]${RESET}"
  display_prompt+=": "

  printf '%b' "$display_prompt" >&2
  local result
  IFS= read -r result
  [[ -z "$result" && -n "$default" ]] && result="$default"
  printf '%s' "$result"
}

# ═══════════════════════════════════════════════════════════════════════════
hdr "⬡  Git Worktree Creator"
echo -e "   repo: ${BOLD}${REPO_NAME}${RESET}  (${REPO_ROOT})"
# ═══════════════════════════════════════════════════════════════════════════

# ── 1. Fetch branch list ──────────────────────────────────────────────────
info "Fetching branch list…"
BRANCHES=$(git branch -a --format='%(refname:short)' | sed 's|^origin/||' | sort -u)

if [[ -z "$BRANCHES" ]]; then
  err "No branches found."
  exit 1
fi

# ── 2. Base branch via fzf ────────────────────────────────────────────────
hdr "Step 1 — Base branch"
BASE_BRANCH=$(echo "$BRANCHES" | fzf \
  --prompt="Base branch > " \
  --height=40% \
  --layout=reverse \
  --border \
  --info=inline) || {
  err "No branch selected. Aborting."
  exit 1
}
ok "Base branch: ${BASE_BRANCH}"

# ── 3. Jira ticket number (optional) ──────────────────────────────────────
hdr "Step 2 — Jira ticket number  (optional — press Enter to skip)"
JIRA_TICKET=$(ask "Jira ticket" "")

# ── 4. Short description ──────────────────────────────────────────────────
hdr "Step 3 — Short description"
if [[ -z "$JIRA_TICKET" ]]; then
  echo -e "  ${YELLOW}Jira ticket was skipped — description is required.${RESET}"
  SHORT_DESC=""
  while [[ -z "$SHORT_DESC" ]]; do
    SHORT_DESC=$(ask "Short description" "")
    [[ -z "$SHORT_DESC" ]] && err "Description cannot be empty when Jira ticket is skipped."
  done
else
  echo -e "  (optional — press Enter to skip)"
  SHORT_DESC=$(ask "Short description" "")
fi

# Normalise: lowercase, non-alphanumeric → hyphens
SHORT_DESC_SLUG=$(echo "$SHORT_DESC" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//')
JIRA_SLUG=$(echo "$JIRA_TICKET" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g')

# ── 5. Worktree directory ─────────────────────────────────────────────────
hdr "Step 4 — Worktree directory"

DIR_PARTS=("$REPO_NAME")
[[ -n "$JIRA_SLUG" ]] && DIR_PARTS+=("$JIRA_SLUG")
[[ -n "$SHORT_DESC_SLUG" ]] && DIR_PARTS+=("$SHORT_DESC_SLUG")

SUGGESTED_DIR=$(
  IFS='-'
  echo "${DIR_PARTS[*]}"
)
DEFAULT_WORKTREE_DIR="$(dirname "$REPO_ROOT")/worktrees/${SUGGESTED_DIR}"

WORKTREE_DIR=$(ask "Worktree directory" "$DEFAULT_WORKTREE_DIR")

# ── 6. SST stage ──────────────────────────────────────────────────────────
if [[ -n "${DEFAULT_SST_STAGE:-}" ]]; then
  SST_STAGE_VALUE="$DEFAULT_SST_STAGE"
else
  hdr "Step 5 — SST stage"
  SST_STAGE_VALUE=""
  while [[ -z "$SST_STAGE_VALUE" ]]; do
    SST_STAGE_VALUE=$(ask "SST stage" "")
    [[ -z "$SST_STAGE_VALUE" ]] && err "SST stage cannot be empty."
  done
fi

# ── 7. Pre-authorize 1Password ────────────────────────────────────────────
# `npm run env` runs `op inject`, which needs an active 1Password session.
# Trigger the unlock now so the biometric/touch prompt happens while the
# user is still at the keyboard — otherwise a long npm install can exhaust
# the auth window and the setup fails with "authorization timeout".
if command -v op &>/dev/null; then
  hdr "Step 6 — 1Password authorization"
  info "Unlocking 1Password (biometric / system prompt may appear)…"
  # `op vault list` actually requires auth, so it triggers the desktop-app
  # biometric dialog when no session is active. `op whoami` would NOT trigger
  # the prompt — it just reports status.
  if op vault list >/dev/null 2>&1; then
    ok "1Password session is active."
  else
    err "1Password unlock failed. You may hit an auth timeout during setup."
    printf '%b' "${BOLD}Continue anyway? [y/N]: ${RESET}"
    read -r OP_CONTINUE
    OP_CONTINUE_LOWER=$(printf '%s' "$OP_CONTINUE" | tr '[:upper:]' '[:lower:]')
    case "$OP_CONTINUE_LOWER" in
    y | yes) ;;
    *)
      info "Aborted."
      exit 1
      ;;
    esac
  fi
fi

# ── 8. New branch name ────────────────────────────────────────────────────
BRANCH_PARTS=()
[[ -n "$JIRA_TICKET" ]] && BRANCH_PARTS+=("$JIRA_TICKET")
[[ -n "$SHORT_DESC_SLUG" ]] && BRANCH_PARTS+=("$SHORT_DESC_SLUG")

NEW_BRANCH=$(
  IFS='/'
  echo "${BRANCH_PARTS[*]}"
)

# ── Confirm ───────────────────────────────────────────────────────────────
hdr "Summary"
echo -e "  Base branch   : ${GREEN}${BASE_BRANCH}${RESET}"
echo -e "  New branch    : ${GREEN}${NEW_BRANCH}${RESET}"
echo -e "  Worktree dir  : ${GREEN}${WORKTREE_DIR}${RESET}"
echo -e "  SST stage     : ${GREEN}${SST_STAGE_VALUE}${RESET}"
echo
printf '%b' "${BOLD}Proceed? [Y/n]: ${RESET}"
read -r CONFIRM
CONFIRM_LOWER=$(printf '%s' "$CONFIRM" | tr '[:upper:]' '[:lower:]')
case "$CONFIRM_LOWER" in
n | no)
  info "Aborted."
  exit 0
  ;;
esac

# ── 9. Create the worktree ────────────────────────────────────────────────
hdr "Creating worktree…"

if git show-ref --verify --quiet "refs/remotes/origin/${BASE_BRANCH}"; then
  info "Fetching origin/${BASE_BRANCH}…"
  git fetch origin "${BASE_BRANCH}:${BASE_BRANCH}" 2>/dev/null || true
fi

git worktree add -b "$NEW_BRANCH" "$WORKTREE_DIR" "$BASE_BRANCH"
ok "Worktree created at ${WORKTREE_DIR}"

# ── 10. Fetch Jira summary in background (if ticket provided) ─────────────
if [[ -n "$JIRA_TICKET" ]]; then
  if command -v claude &>/dev/null; then
    JIRA_LOG="${WORKTREE_DIR}/.claude-jira-fetch.log"
    info "Fetching Jira summary for ${JIRA_TICKET} in background → ${JIRA_TICKET}.md"
    (
      cd "$WORKTREE_DIR"
      nohup claude -p --dangerously-skip-permissions \
        "Use the Atlassian MCP to fetch Jira ticket ${JIRA_TICKET} and write a concise markdown summary to ./${JIRA_TICKET}.md in the current directory. Include: title, status, assignee, reporter, priority, a short description, acceptance criteria (if present), and links to related issues. Keep it under ~150 lines." \
        >"$JIRA_LOG" 2>&1 &
      disown
    ) >/dev/null 2>&1
  else
    err "claude CLI not found — skipping Jira summary fetch."
  fi
fi

# ── 11. Setup steps ───────────────────────────────────────────────────────
hdr "Running setup…"

(
  cd "$WORKTREE_DIR"

  info "npm install"
  npm i

  info "Setting up env  (SST_STAGE=${SST_STAGE_VALUE})"
  SST_STAGE="${SST_STAGE_VALUE}" npm run env

  info "Resetting Salesforce tracking"
  sf project reset tracking -p
)

# ── Done ──────────────────────────────────────────────────────────────────
hdr "✅  All done!"
echo -e "  Worktree : ${GREEN}${WORKTREE_DIR}${RESET}"
echo -e "  Branch   : ${GREEN}${NEW_BRANCH}${RESET}"
echo
echo -e "  To switch to the worktree:\n    ${BOLD}cd ${WORKTREE_DIR}${RESET}"
